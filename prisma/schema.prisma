// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String  @id
  name     String
  email    String  @unique
  password String
  role     Role    @default(user)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lastPackDate String?
  avatar       String?
  userCards    UserCard[]
}

model Group {
  id          String   @id
  name        String
  description String?
  coverImage  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards Card[]
}

model Card {
  id        String   @id
  name      String
  image     String
  rarity    String
  type      String
  groupId   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  group Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)
}

model UserCard {
  id     String @id
  userId String
  cardId String
  count  Int    @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
}

// Enums
enum Role {
  user
  admin
}
